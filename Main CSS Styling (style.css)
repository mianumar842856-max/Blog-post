body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#f4f7fb;
}

.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 60px;
    background:#0f172a;
}

.logo{
    color:white;
    font-size:28px;
    font-weight:bold;
}

.nav-links{
    display:flex;
    list-style:none;
}

.nav-links li{
    margin-left:30px;
}

.nav-links li a{
    color:white;
    text-decoration:none;
}

.hero{
    height:90vh;
    background:linear-gradient(135deg,#1e3a8a,#2563eb);
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    text-align:center;
}

.hero h1{
    font-size:60px;
}

.hero-btn{
    padding:15px 30px;
    background:white;
    color:#2563eb;
    border-radius:10px;
    text-decoration:none;
}

.statistics{
    display:flex;
    justify-content:center;
    gap:40px;
    padding:60px;
}

.stat-card{
    background:white;
    padding:30px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.1);
}

.post-card{
    width:80%;
    margin:40px auto;
    background:white;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 5px 20px rgba(0,0,0,.1);
}

.post-card img{
    width:100%;
}

.post-content{
    padding:30px;
}
